# Example environment variables for the MCP server
# Copy this file to .env and fill in your actual values
# NEVER commit the .env file with real credentials!

# OpenAI API Key
OPENAI_API_KEY={{OPENAI_API_KEY}}

# MCP Server Environment Variables (JSON string)
ENV_MCP_VARIABLES={"id_field":"{{id_field}}","GOOGLE_CLIENT_ID":"{{GOOGLE_CLIENT_ID}}","GOOGLE_CLIENT_SECRET":"{{GOOGLE_CLIENT_SECRET}}","GOOGLE_REFRESH_TOKEN":"{{GOOGLE_REFRESH_TOKEN}}"}

# Alternative: Individual environment variables
# id_field={{id_field}}
# GOOGLE_CLIENT_ID={{GOOGLE_CLIENT_ID}}
# GOOGLE_CLIENT_SECRET={{GOOGLE_CLIENT_SECRET}}
# GOOGLE_REFRESH_TOKEN={{GOOGLE_REFRESH_TOKEN}}

# InfluxDB variables (if using InfluxDB MCP server)
# INFLUX_DB_INSTANCE_URL={{INFLUX_DB_INSTANCE_URL}}
# INFLUX_DB_TOKEN={{INFLUX_DB_TOKEN}}
